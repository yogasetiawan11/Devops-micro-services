# Boutique Database Configuration
# Environment variables for database connections

# Database connection settings
export DB_HOST=localhost
export DB_PORT=5432
export DB_NAME=boutique_auth
export DB_USER=postgres
export DB_PASSWORD=your_password_here

# Connection string format
# postgresql://[user[:password]@][host][:port][/dbname][?param1=value1&...]
export DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"

# SSL settings
export DB_SSLMODE=prefer

# Connection pool settings (for applications)
export DB_POOL_MIN=2
export DB_POOL_MAX=10

# Microservice specific connections
export USER_SERVICE_DB_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"
export PRODUCT_SERVICE_DB_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"
export ORDER_SERVICE_DB_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"
export REVIEW_SERVICE_DB_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"