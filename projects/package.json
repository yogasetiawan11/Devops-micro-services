{
  "name": "boutique-microservices",
  "version": "1.0.0",
  "description": "Enterprise microservices boutique application",
  "scripts": {
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install && cd services && for dir in */; do cd \"$dir\" && npm install && cd ..; done",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm start",
    "dev:backend": "cd backend && npm run dev:services",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm run test",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "frontend",
    "backend/*",
    "backend/services/*"
  ]
}